// ============================================================
// Prisma Schema — Digital Top‑Up Store (Minimal)
// Generator: prisma-client (Prisma 7+)
// DB: PostgreSQL
// Auth: better-auth (User, Session, Account, Verification untouched)
// ============================================================

generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

// ============================================================
// BETTER-AUTH TABLES (do not modify structure)
// ============================================================

model User {
  id            String    @id
  name          String
  email         String    @unique
  emailVerified Boolean
  image         String?
  createdAt     DateTime
  updatedAt     DateTime
  
  // admin
  role          String?
  banned        Boolean?
  banReason     String?
  banExpires    DateTime? @db.Timestamptz(3)

  // telegram
  telegramId          String?
  telegramUsername    String?
  telegramPhoneNumber String?

  // relations
  sessions     Session[]
  accounts     Account[]
  orders       Order[]
  payments     Payment[]
  transactions Transaction[]
  carts        Cart[]

  @@map("user")
}

model Session {
  id             String   @id
  expiresAt      DateTime
  token          String   @unique
  createdAt      DateTime
  updatedAt      DateTime
  ipAddress      String?
  userAgent      String?
  userId         String
  user           User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  impersonatedBy String?

  @@map("session")
}

model Account {
  id                    String    @id
  accountId             String
  providerId            String
  userId                String
  user                  User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  accessToken           String?
  refreshToken          String?
  idToken               String?
  accessTokenExpiresAt  DateTime?
  refreshTokenExpiresAt DateTime?
  scope                 String?
  password              String?
  createdAt             DateTime
  updatedAt             DateTime
  telegramId            String?
  telegramUsername      String?

  @@map("account")
}

model Verification {
  id         String    @id
  identifier String
  value      String
  expiresAt  DateTime
  createdAt  DateTime?
  updatedAt  DateTime?

  @@map("verification")
}

// ============================================================
// CATALOG
// ============================================================

model Category {
  id        String    @id @default(cuid())
  name      String
  slug      String    @unique
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt

  products  Product[]

  @@map("category")
}

model Product {
  id          String    @id @default(cuid())
  categoryId  String
  category    Category  @relation(fields: [categoryId], references: [id], onDelete: Cascade)

  type        String    // e.g. "diamond", "uc", "stars", "level-up", "membership", "premium", "robux", "cp"
  name        String    // display name, e.g. "Free Fire Diamonds"
  isActive    Boolean   @default(true)
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  
  packages    Package[]

  @@unique([categoryId, type])
  @@map("product")
}

model Package {
  id        String   @id @default(cuid())
  productId String
  product   Product  @relation(fields: [productId], references: [id], onDelete: Cascade)

  label     String   // e.g. "110 Diamonds", "Level 6", "Weekly Membership"

  // Variant fields (only relevant ones per type)
  amount    Int?     // for amount-based types
  level     Int?     // for level-up
  diamonds  Int?     // for level-up (diamonds consumed)
  membershipName String? // for membership
  duration  String?  // for premium

  price     Int      // in ETB (smallest unit)
  


  isActive  Boolean   @default(true)
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  
  orderItems OrderItem[]
  cartItems  Cart[]  
  sku String @unique
  
  @@map("package")
}

model Cart {
  id        String  @id @default(cuid())
  userId    String
  user      User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  packageId String
  package   Package @relation(fields: [packageId], references: [id], onDelete: Restrict)

  quantity  Int     @default(1)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("cart")
}

// ============================================================
// ORDERS
// ============================================================

model Order {
  id          String      @id @default(cuid())
  userId      String
  user        User        @relation(fields: [userId], references: [id], onDelete: Restrict)

  status      OrderStatus @default(PENDING)

  totalAmount Int         // sum of item subtotals in ETB

  targetId    String?     // game UID, phone number, etc.
  targetNote  String?     // extra context

  fulfilmentRef String?
  fulfilmentRaw Json?     // raw response for debugging

  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt

  items       OrderItem[]
  payment     Payment?

  @@index([userId])
  @@index([status])
  @@map("order")
}

model OrderItem {
  id        String  @id @default(cuid())
  orderId   String
  order     Order   @relation(fields: [orderId], references: [id], onDelete: Cascade)
  packageId String
  package   Package @relation(fields: [packageId], references: [id], onDelete: Restrict)

  quantity  Int     @default(1)
  unitPrice Int     // snapshot of price at time of order
  subtotal  Int     // quantity * unitPrice

  @@map("order_item")
}

enum OrderStatus {
  PENDING
  AWAITING_PAYMENT
  PROCESSING
  COMPLETED
  FAILED
  CANCELLED
  REFUNDED

  @@map("order_status")
}

// ============================================================
// PAYMENTS
// ============================================================

model Payment {
  id      String        @id @default(cuid())
  orderId String        @unique
  order   Order         @relation(fields: [orderId], references: [id], onDelete: Restrict)
  userId  String
  user    User          @relation(fields: [userId], references: [id], onDelete: Restrict)

  status      PaymentStatus   @default(INITIATED)

  amount      Int             

  checkoutUrl String?         // Chapa checkout URL
  providerRef String?         @unique // Chapa transaction reference
  providerRaw Json?           // webhook payload

  paidAt      DateTime?
  createdAt   DateTime        @default(now())
  updatedAt   DateTime        @updatedAt

  transaction Transaction?

  @@index([userId])
  @@index([status])
  @@map("payment")
}

enum PaymentStatus {
  INITIATED
  PENDING
  SUCCESS
  FAILED
  EXPIRED
  REFUNDED

  @@map("payment_status")
}

// ============================================================
// TRANSACTIONS  (immutable ledger)
// ============================================================


model Transaction {
  id        String          @id @default(cuid())
  paymentId String          @unique
  payment   Payment         @relation(fields: [paymentId], references: [id], onDelete: Restrict)
  userId    String
  user      User            @relation(fields: [userId], references: [id], onDelete: Restrict)

  amount    Int             // positive = credit, negative = debit (if needed)

  createdAt DateTime        @default(now())

  @@index([userId])
  @@map("transaction")
}
